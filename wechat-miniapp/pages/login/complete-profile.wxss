/* 信息补充页样式 */
.container {
  min-height: 100vh;
  background: #f5f7fa;
}

/* 步骤指示器 */
.header {
  background: #fff;
  padding: 40rpx 60rpx;
}

.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-num {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #ddd;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  margin-bottom: 10rpx;
}

.step.active .step-num {
  background: #1E5AA8;
}

.step text {
  font-size: 24rpx;
  color: #999;
}

.step.active text {
  color: #1E5AA8;
}

.step-line {
  width: 80rpx;
  height: 2rpx;
  background: #ddd;
  margin: 0 20rpx;
  margin-bottom: 30rpx;
}

/* 表单区域 */
.form-section {
  padding: 40rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 40rpx;
}

.form-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
  font-weight: 500;
}

.input {
  width: 100%;
  height: 80rpx;
  background: #f5f7fa;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.textarea {
  width: 100%;
  height: 160rpx;
  background: #f5f7fa;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker {
  width: 100%;
  height: 80rpx;
  background: #f5f7fa;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  color: #333;
}

.picker.placeholder {
  color: #999;
}

.arrow {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.5;
}

.tips {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 40rpx;
  font-size: 24rpx;
  color: #999;
}

.tip-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 10rpx;
}

/* 底部 */
.footer {
  padding: 40rpx 60rpx 60rpx;
}

.submit-btn {
  width: 100%;
  height: 100rpx;
  background: #ccc;
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
  line-height: 100rpx;
  border: none;
}

.submit-btn::after {
  border: none;
}

.submit-btn.active {
  background: linear-gradient(135deg, #1E5AA8 0%, #164785 100%);
  box-shadow: 0 8rpx 20rpx rgba(30, 90, 168, 0.3);
}
