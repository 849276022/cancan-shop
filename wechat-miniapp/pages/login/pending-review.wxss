/* 等待审核页样式 */
.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 40rpx;
}

/* 状态区域 */
.status-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  margin-bottom: 30rpx;
}

.status-icon {
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 30rpx;
}

.status-icon image {
  width: 100%;
  height: 100%;
}

.status-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1E5AA8;
  margin-bottom: 20rpx;
}

.status-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

/* 进度区域 */
.info-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
}

.info-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 40rpx;
}

.progress-list {
  padding-left: 20rpx;
}

.progress-item {
  display: flex;
  align-items: flex-start;
  position: relative;
}

.progress-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #ddd;
  margin-right: 30rpx;
  margin-top: 6rpx;
  flex-shrink: 0;
}

.progress-item.completed .progress-dot {
  background: #28A745;
}

.progress-item.active .progress-dot {
  background: #1E5AA8;
  box-shadow: 0 0 0 8rpx rgba(30, 90, 168, 0.2);
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.progress-content {
  flex: 1;
  padding-bottom: 40rpx;
}

.progress-label {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.progress-item.completed .progress-label {
  color: #28A745;
}

.progress-item.active .progress-label {
  color: #1E5AA8;
  font-weight: 500;
}

.progress-time {
  font-size: 24rpx;
  color: #999;
}

.progress-line {
  width: 2rpx;
  height: 60rpx;
  background: #ddd;
  margin-left: 11rpx;
  margin-bottom: 10rpx;
}

.progress-line.completed {
  background: #28A745;
}

.progress-line.active {
  background: linear-gradient(180deg, #28A745 0%, #1E5AA8 100%);
}

/* 通知区域 */
.notice-section {
  background: #FFF7ED;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
}

.notice-title {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 30rpx;
  font-weight: bold;
  color: #FF6B35;
}

.notice-title image {
  width: 36rpx;
  height: 36rpx;
  margin-right: 15rpx;
}

.notice-list {
  padding-left: 10rpx;
}

.notice-item {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

/* 底部 */
.footer {
  text-align: center;
}

.home-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #1E5AA8 0%, #164785 100%);
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
  line-height: 100rpx;
  border: none;
  margin-bottom: 30rpx;
}

.home-btn::after {
  border: none;
}

.refresh-tips {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #1E5AA8;
}

.refresh-icon {
  width: 32rpx;
  height: 32rpx;
  margin-left: 10rpx;
}

.refresh-icon.spin {
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
