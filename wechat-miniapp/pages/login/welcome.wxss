/* 欢迎页样式 */
.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
}

/* Logo区域 */
.logo-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 80rpx;
}

.logo-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 20rpx;
}

.slogan {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 登录区域 */
.login-section {
  padding: 60rpx 60rpx 40rpx;
}

.wechat-login-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #07C160 0%, #05a350 100%);
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(7, 193, 96, 0.3);
}

.wechat-login-btn::after {
  border: none;
}

.wechat-login-btn[disabled] {
  opacity: 0.7;
}

.wechat-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.wechat-login-btn text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
}

/* 协议勾选 */
.agreement-section {
  margin-top: 40rpx;
  display: flex;
  justify-content: center;
}

.agreement-label {
  display: flex;
  align-items: flex-start;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.agreement-text {
  margin-left: 10rpx;
  line-height: 1.5;
}

.link {
  color: #60a5fa;
}

/* 底部 */
.footer {
  padding: 40rpx 60rpx 60rpx;
  text-align: center;
}

.security-tips {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  font-size: 24rpx;
  color: #28A745;
}

.lock-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.authority-tips {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
  z-index: 1000;
}

.modal.show {
  opacity: 1;
  pointer-events: auto;
}

.modal-content {
  width: 80%;
  max-height: 70%;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-body {
  max-height: 600rpx;
  padding: 30rpx;
  font-size: 28rpx;
  line-height: 1.8;
  color: #333;
}

.modal-footer {
  padding: 20rpx 30rpx 30rpx;
  border-top: 1rpx solid #eee;
}

.modal-btn {
  width: 100%;
  height: 80rpx;
  background: #1E5AA8;
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
  line-height: 80rpx;
}

.modal-btn::after {
  border: none;
}
