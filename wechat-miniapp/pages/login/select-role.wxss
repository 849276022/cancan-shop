/* 角色选择页样式 */
.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 40rpx;
}

/* 头部 */
.header {
  text-align: center;
  padding: 60rpx 0;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #999;
}

/* 角色列表 */
.role-list {
  margin-bottom: 60rpx;
}

.role-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.role-card.selected {
  border-color: #1E5AA8;
  box-shadow: 0 4rpx 20rpx rgba(30, 90, 168, 0.15);
}

.role-icon-wrapper {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
  flex-shrink: 0;
}

.role-icon-wrapper.family {
  background: #FFF5F5;
}

.role-icon-wrapper.staff {
  background: #F0F9FF;
}

.role-icon-wrapper.admin {
  background: #FFF7ED;
}

.role-icon {
  width: 60rpx;
  height: 60rpx;
}

.role-info {
  flex: 1;
}

.role-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.role-desc {
  font-size: 26rpx;
  color: #999;
  line-height: 1.5;
}

.check-icon {
  width: 48rpx;
  height: 48rpx;
  opacity: 0;
  transition: opacity 0.3s;
}

.check-icon.show {
  opacity: 1;
}

.check-icon image {
  width: 100%;
  height: 100%;
}

/* 底部 */
.footer {
  padding: 0 20rpx;
}

.confirm-btn {
  width: 100%;
  height: 100rpx;
  background: #ccc;
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
  line-height: 100rpx;
  border: none;
  transition: all 0.3s;
}

.confirm-btn::after {
  border: none;
}

.confirm-btn.active {
  background: linear-gradient(135deg, #1E5AA8 0%, #164785 100%);
  box-shadow: 0 8rpx 20rpx rgba(30, 90, 168, 0.3);
}

.tips {
  text-align: center;
  margin-top: 30rpx;
  font-size: 24rpx;
  color: #999;
}
