/* ========== 记录页样式 ========== */

.search-box {
  position: relative;
  margin-bottom: 20rpx;
}
.search-box input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx 0 68rpx;
  background: var(--bg-card);
  border: 1rpx solid var(--border-light);
  border-radius: 16rpx;
  color: var(--text-primary);
  font-size: 28rpx;
  box-sizing: border-box;
}
.search-box .search-icon {
  position: absolute;
  left: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 28rpx;
}

/* 时间线徽章 */
.timeline-type-badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  background: var(--accent-glow);
  border-radius: 8rpx;
}
.timeline-type-badge .timeline-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--accent);
}

/* 时间线内容 */
.timeline-content { margin-left: 0; }
.timeline-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.timeline-time {
  font-size: 22rpx;
  color: var(--text-muted);
}
.timeline-body {
  font-size: 28rpx;
  margin-bottom: 12rpx;
}
.timeline-name {
  font-weight: 700;
  color: var(--text-primary);
}
.timeline-result {
  color: var(--text-secondary);
}
.timeline-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

/* 新增浮动按钮定位 */
.fab-container {
  position: fixed;
  bottom: 160rpx;
  right: 32rpx;
  z-index: 100;
}