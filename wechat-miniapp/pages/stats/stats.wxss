/* ========== 统计页样式 ========== */

.stat-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
  color: var(--text-primary);
}

/* 摘要卡片 */
.summary-grid {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.summary-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  background: var(--bg-deep);
  border-radius: 16rpx;
  border: 1rpx solid var(--border-light);
}
.summary-num {
  font-size: 40rpx;
  font-weight: 800;
  display: block;
  line-height: 1;
  margin-bottom: 8rpx;
}
.summary-label {
  font-size: 20rpx;
  color: var(--text-muted);
}