/* ========== 首页专用样式 ========== */

/* 头部统计 */
.header-stats {
  display: flex;
  justify-content: space-around;
  background: linear-gradient(135deg, #1e293b 0%, #1a2744 100%);
  border-radius: 24rpx;
  padding: 36rpx 24rpx;
  margin-bottom: 28rpx;
  border: 1rpx solid rgba(96,165,250,0.1);
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.3);
}
.stat-item { text-align: center; flex: 1; }
.stat-num {
  font-size: 52rpx;
  font-weight: 800;
  color: var(--accent);
  display: block;
  line-height: 1;
  margin-bottom: 8rpx;
}
.stat-desc {
  font-size: 22rpx;
  color: var(--text-muted);
  font-weight: 500;
  letter-spacing: 2rpx;
}
.stat-pending { color: var(--warning) !important; }
.stat-found { color: var(--success) !important; }

/* 人员列表 */
.person-list { padding-bottom: 40rpx; }

/* 人员卡片 */
.person-card {
  transition: transform 0.15s ease;
}
.person-card:active { transform: scale(0.98); }

/* 卡片头部 */
.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  gap: 16rpx;
}

/* 头像样式 */
.person-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  background: linear-gradient(135deg, #334155, #1e293b);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(96,165,250,0.2);
}
.avatar-img {
  width: 100%;
  height: 100%;
}
.avatar-text {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--accent);
}

.person-info { flex: 1; }
.person-name {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-right: 12rpx;
}
.person-meta {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 400;
  margin-left: 12rpx;
}

/* 搜索栏样式 */
.search-bar {
  position: relative;
  margin-bottom: 20rpx;
}
.search-bar input {
  height: 80rpx;
  padding: 0 24rpx 0 68rpx;
  background: var(--bg-card);
  border: 1rpx solid var(--border-light);
  border-radius: 16rpx;
  color: var(--text-primary);
  font-size: 28rpx;
}
.search-bar .search-icon {
  position: absolute;
  left: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 28rpx;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}
.filter-item {
  padding: 14rpx 28rpx;
  background: var(--bg-card);
  border: 1rpx solid var(--border-light);
  border-radius: 24rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
  white-space: nowrap;
}

/* 卡片照片展示 */
.card-photo {
  margin-bottom: 16rpx;
  border-radius: 16rpx;
  overflow: hidden;
}
.photo-img {
  width: 100%;
  height: 360rpx;
  border-radius: 16rpx;
}

/* 表单照片上传 */
.photo-upload-area {
  margin-top: 12rpx;
}
.photo-upload-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 240rpx;
  background: var(--bg-card);
  border: 2rpx dashed var(--border-light);
  border-radius: 16rpx;
  color: var(--text-secondary);
}
.photo-upload-btn:active {
  background: rgba(96,165,250,0.1);
}
.photo-upload-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}
.photo-upload-text {
  font-size: 24rpx;
  color: var(--text-muted);
}
.photo-preview-container {
  position: relative;
  width: 100%;
  height: 360rpx;
  border-radius: 16rpx;
  overflow: hidden;
}
.photo-preview-img {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}
.photo-remove {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 48rpx;
  height: 48rpx;
  background: rgba(0,0,0,0.6);
  border-radius: 50%;
  color: #fff;
  text-align: center;
  line-height: 48rpx;
  font-size: 28rpx;
  font-weight: bold;
}
.photo-remove:active {
  background: rgba(239,68,68,0.9);
}